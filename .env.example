# ============================================
# MS ADHÉSIF — Environment Variables Template
# Copy this file to .env and fill in values.
# NEVER commit .env — it contains secrets.
# ============================================

# ─── Database (PostgreSQL 16) ─────────────────────────────────────────────────
# Local dev: docker compose expose port 5433 (avoids conflict with local postgres)
DATABASE_URL=postgresql://msadhesif:CHANGE_ME@localhost:5433/msadhesif

# Production (set to internal Docker hostname):
# DATABASE_URL=postgresql://msadhesif:CHANGE_ME@postgres:5432/msadhesif

POSTGRES_USER=msadhesif
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=msadhesif

# ─── Better-Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGE_ME_32_CHAR_RANDOM_SECRET
BETTER_AUTH_URL=https://msadhesif.fr

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLIC_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_...

# Test keys (for development):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_...

# ─── Pennylane ────────────────────────────────────────────────────────────────
PENNYLANE_API_KEY=CHANGE_ME
PENNYLANE_API_BASE=https://app.pennylane.com/api/external/v2
# Secret partagé pour vérifier les webhooks Pennylane (optionnel mais recommandé)
PENNYLANE_WEBHOOK_SECRET=CHANGE_ME

# ─── Object Storage (Scaleway S3-compatible) ──────────────────────────────────
# Production (Scaleway):
SCW_ACCESS_KEY=CHANGE_ME
SCW_SECRET_KEY=CHANGE_ME
SCW_BUCKET=ms-adhesif
SCW_REGION=fr-par
SCW_ENDPOINT=https://s3.fr-par.scw.cloud

# Development (MinIO via docker-compose):
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=msadhesif
# MINIO_SECRET_KEY=msadhesif_secret
# MINIO_BUCKET=ms-adhesif
# MINIO_USE_SSL=false

# ─── Brevo (transactional email) ──────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=hello@msadhesif.fr
BREVO_FROM_NAME=MS Adhésif
BREVO_ADMIN_EMAIL=hello@msadhesif.fr

# ─── SendCloud (shipping) ─────────────────────────────────────────────────────
SENDCLOUD_PUBLIC_KEY=CHANGE_ME
SENDCLOUD_SECRET_KEY=CHANGE_ME
SENDCLOUD_FROM_ADDRESS_ID=CHANGE_ME
SENDCLOUD_INTEGRATION_ID=CHANGE_ME
SENDCLOUD_DEFAULT_SHIPPING_CODE=colissimo:home/fr
SENDCLOUD_DEFAULT_WEIGHT_GRAMS=200

# ─── VIES VAT validation cache ────────────────────────────────────────────────
VIES_CACHE_TTL_HOURS=24

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://msadhesif.fr
APP_ENV=production
# APP_ENV=development
